      "title": "Token Consumption Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "id": 7,
      "targets": [
        { "expr": "rate(sentinel_prompt_tokens_total[5m])", "legendFormat": "Prompt Tokens/s" },
        { "expr": "rate(sentinel_completion_tokens_total[5m])", "legendFormat": "Completion Tokens/s" }
      ]
    }
